# ──────────────────────────────────────────────────
# AI Endpoint — optional, for AI-enhanced generation
# Uses OpenAI-compatible chat completions format
# ──────────────────────────────────────────────────
AI_ENDPOINT=https://api.openai.com/v1/chat/completions
AI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4o

# ──────────────────────────────────────────────────
# Your business config (used in templates)
# ──────────────────────────────────────────────────
COMPANY_NAME="AIMS SG"
COMPANY_DOMAIN="aims-sg.com"
COMPANY_TAGLINE="Agentic AI Business Transformation for Singapore SMEs"
INDUSTRY="AI Business Transformation"
TARGET_AUDIENCE="Singapore SME and enterprise decision-makers"
PRIMARY_COUNTRY="Singapore"
SUPPORT_EMAIL="hello@aims-sg.com"
CALENDLY_LINK="https://calendly.com/your-link"
BREVO_API_KEY=""

# ──────────────────────────────────────────────────
# Background marketing daemon — PM2-compatible
# ──────────────────────────────────────────────────
MARKETING_DAEMON_INTERVAL_SECONDS=300
MARKETING_ENV_FILE=.env
MARKETING_LOG_FILE=logs/marketing-combined.log
MARKETING_STATUS_FILE=output/status/latest-status.md
MARKETING_OUTPUT_DIR=output
MARKETING_STATE_DIR=output/status/daemon-state
MARKETING_ENABLE_AI=false
MARKETING_ENABLE_OUTREACH=false
MARKETING_PROSPECTS_CSV=prospects.csv
