#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(dirname "$0")")" && pwd)"
source "$SCRIPT_DIR/lib/helpers.sh"

load_env
require_var COMPANY_NAME
require_var COMPANY_DOMAIN

header "Share of Model (SoM) Tracker — Layer 3"

output_file="${1:-output/som-tracker.md}"
data_dir="$(dirname "$output_file")/som-data"
mkdir -p "$data_dir"

cat > "$output_file" <<HEADER
# Share of Model (SoM) Tracking Sheet

**Company:** $COMPANY_NAME
**Domain:** $COMPANY_DOMAIN
**Last updated:** $(date '+%Y-%m-%d %H:%M')
**Track:** AI Transformation (Track B)

---

## How to use this

For each query below:
1. Ask the AI engine the query.
2. Note whether $COMPANY_NAME is cited.
3. Record the cited brand(s) and sentiment.
4. Repeat weekly to track trends.

**SoM formula:** \`(your citations ÷ total citations across all queries) × 100\`

