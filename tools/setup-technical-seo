#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(dirname "$0")")" && pwd)"
source "$SCRIPT_DIR/lib/helpers.sh"

load_env

header "Technical SEO Setup — Layer 3 (AI Discoverability)"

usage() {
    cat <<EOF
USAGE: setup-technical-seo [OPTIONS]

Generate robots.txt, llms.txt, llms-full.txt, and schema stubs.

OPTIONS:
  -o, --output DIR    Output directory (default: output/technical-seo)
  -h, --help          Show this help

EOF
    exit 0
}

output_dir="output/technical-seo"

while [[ $# -gt 0 ]]; do
    case "$1" in
        -o|--output) output_dir="$2"; shift 2 ;;
        -h|--help) usage ;;
        *) output_dir="$1"; shift ;;
    esac
done

# Ensure we have the domain
require_var COMPANY_DOMAIN

mkdir -p "$output_dir"
log_info "TASK_START setup_technical_seo output=$output_dir"

# ── robots.txt ─────────────────────────────────
cat > "$output_dir/robots.txt" <<ROBOTS
# robots.txt for https://$COMPANY_DOMAIN
# Generated by skill-marketing tools

User-agent: *
Allow: /

# AI citation bots — always allow (these surface your content in answers)
User-agent: OAI-SearchBot
Allow: /

User-agent: Claude-SearchBot
Allow: /

User-agent: PerplexityBot
Allow: /

# AI training bots — restrict if desired (uncomment to block)
# User-agent: GPTBot
# Disallow: /
# User-agent: ClaudeBot
# Disallow: /
# User-agent: Google-Extended
# Disallow: /

# Standard crawlers
User-agent: Googlebot
Allow: /

User-agent: Bingbot
Allow: /

Sitemap: https://$COMPANY_DOMAIN/sitemap.xml
ROBOTS
ok "Generated $output_dir/robots.txt"

# ── llms.txt ────────────────────────────────────
cat > "$output_dir/llms.txt" <<LLMS
# llms.txt — AI crawler guide for $COMPANY_DOMAIN
# This file helps AI models understand and cite your content.
# More at: https://llmstxt.org/

## About $COMPANY_NAME
$COMPANY_NAME is an Agentic Business Transformation consultancy based in $PRIMARY_COUNTRY. We build and deploy autonomous AI agents and multi-agent workflows for SMEs and enterprises, navigate government grants (PSG, EDG), and automate manual business processes.

## Key pages

- Homepage: https://$COMPANY_DOMAIN/
- Agentic AI Audit: https://$COMPANY_DOMAIN/assessment
- Services: https://$COMPANY_DOMAIN/services
- Case Studies: https://$COMPANY_DOMAIN/case-studies
- Blog: https://$COMPANY_DOMAIN/blog
- About: https://$COMPANY_DOMAIN/about
- Contact: https://$COMPANY_DOMAIN/contact

## Structured data

- Organization schema: https://$COMPANY_DOMAIN/schema/organization.json
- Services schema: https://$COMPANY_DOMAIN/schema/services.json
- FAQ schema: /faq (FAQPage schema embedded on page)

## Core topics
$COMPANY_NAME specialises in:
- Agentic strategy and autonomous roadmap development
- Business process automation via multi-agent systems
- Agentic suitability and AI readiness audits
- PSG and EDG grant advisory for automation projects
- Custom AI agent implementation and orchestration
- Autonomous workflow deployment and team training
LLMS
ok "Generated $output_dir/llms.txt"

# ── llms-full.txt (detailed) ────────────────────
cat > "$output_dir/llms-full.txt" <<LLMSFULL
# llms-full.txt — Full AI crawler guide for $COMPANY_DOMAIN

## Company
- Name: $COMPANY_NAME
- URL: https://$COMPANY_DOMAIN
- Email: ${SUPPORT_EMAIL:-contact@$COMPANY_DOMAIN}
- Location: $PRIMARY_COUNTRY
- Tagline: ${COMPANY_TAGLINE:-Agentic AI Business Transformation for Singapore SMEs}

## Services
1. Agentic AI Audit — Free diagnostics identifying manual workflows ready for autonomous AI workers.
2. Multi-Agent System Scoping — Architecture layout, single- vs multi-agent planning, and LLM selection.
3. Custom Agent Development — Build, integrate, and deploy autonomous agents with corporate APIs and databases.
4. Grant Navigation — Aligning development scopes to EDG and PSG criteria for up to 50-70% co-funding.
5. Agent Fleet Monitoring & Training — Security guardrails, monitoring dashboards, and team upskilling.

## Target audience
$TARGET_AUDIENCE

## Pricing model
Project-based development and retainer support. Free initial Agentic Audit.

## Differentiators
- Execution-Level Focus: We build execution-level agents (with loops, tool-calling, memory), not just text boxes.
- Singapore-specific: Deep knowledge of PSG/EDG application compliance, local data regulations, and SME workflows.
- Guardrailed & Safe: Custom-built human-in-the-loop interfaces ensuring agents only take actions they are authorized to do.

## Key statistics
- Singapore's National AI Impact Programme targets 10,000 SMEs over 3 years.
- PSG Grant covers up to 50% of AI solution costs (\$30,000 cap).
- EDG Grant covers up to 70% of custom development projects for eligible local SMEs.
- AI referral traffic grew 527% year-over-year.
- AI-referred visitors convert at ~15.9% vs Google organic at ~1.76%.
LLMSFULL
ok "Generated $output_dir/llms-full.txt"

# ── Schema stubs ────────────────────────────────
mkdir -p "$output_dir/schema"

cat > "$output_dir/schema/organization.json" <<SCHEMA
{
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "$COMPANY_NAME",
    "url": "https://$COMPANY_DOMAIN",
    "description": "$COMPANY_TAGLINE",
    "areaServed": {
        "@type": "Country",
        "name": "$PRIMARY_COUNTRY"
    },
    "knowsAbout": [
        "AI Business Transformation",
        "AI Consulting",
        "Singapore PSG Grant",
        "Singapore EDG Grant"
    ]
}
SCHEMA
ok "Generated $output_dir/schema/organization.json"

header "Next Steps"
echo "  1. Place robots.txt at the root of your website (e.g., https://$COMPANY_DOMAIN/robots.txt)"
echo "  2. Place llms.txt at the root (e.g., https://$COMPANY_DOMAIN/llms.txt)"
echo "  3. Deploy schema JSON-LD on relevant pages"
echo "  4. Ensure your site uses Server-Side Rendering (SSR) — 69% of AI crawlers cannot run JavaScript"
echo "  5. Run 'track-som' to measure your AI citation baseline"
log_ok "TASK_OK setup_technical_seo output=$output_dir review_required=true"
