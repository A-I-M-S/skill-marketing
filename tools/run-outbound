#!/usr/bin/env python3
import sys
import argparse
from pathlib import Path

# Add lib directory to Python path
sys.path.append(str(Path(__file__).parent.parent / "lib"))

import leads_engine

def main():
    parser = argparse.ArgumentParser(
        description="AIMS Outbound Marketing & Lead Generation Engine.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # 1. Harvest 50 new leads automatically to leads.csv:
  ./tools/run-outbound --harvest 50

  # 2. Upload a custom CSV list of prospects to leads.csv:
  ./tools/run-outbound --import prospects.csv

  # 3. Deliver live campaign outreach (live delivery and Attio updates):
  ./tools/run-outbound --send --count 10

  # 4. Personalize a run and route emails to your own test inbox for review:
  ./tools/run-outbound --test developer@aims-sg.com --count 2

  # 5. Run a local draft dry-run (Default action if executing campaign):
  ./tools/run-outbound --draft-only --count 10
"""
    )
    
    parser.add_argument(
        "--harvest",
        type=int,
        metavar="N",
        help="Step 1a: Harvest N new leads from automated API crawlers and append to leads.csv."
    )
    parser.add_argument(
        "--import",
        type=str,
        dest="import_path",
        metavar="CSV_PATH",
        help="Step 1b: Path to a custom CSV file to import, de-duplicate, and append to leads.csv."
    )
    parser.add_argument(
        "--count",
        type=int,
        default=200,
        help="The maximum number of prospects to process in Step 2 outbound campaign (default: 200)."
    )
    
    # Mode selection
    mode_group = parser.add_mutually_exclusive_group()
    mode_group.add_argument(
        "--draft-only",
        action="store_true",
        help="Step 2: Dry-run campaign, saving generated drafts locally to drafts_today.json (Default)."
    )
    mode_group.add_argument(
        "--test",
        type=str,
        metavar="EMAIL",
        help="Step 2: Dry-run campaign but send all customized emails to this test address."
    )
    mode_group.add_argument(
        "--send",
        action="store_true",
        help="Step 2: LIVE outreach - send customized emails via Brevo and update Attio CRM."
    )

    args = parser.parse_args()

    # Determine mode string
    mode = "draft-only"
    test_address = None
    if args.send:
        mode = "send"
    elif args.test:
        mode = "test"
        test_address = args.test

    leads_engine.log_msg("INFO", "Initializing Outbound Tool Wrapper...")

    run_step1 = bool(args.harvest is not None or args.import_path is not None)
    run_step2 = bool(args.send or args.test is not None or args.draft_only or not run_step1)

    # Action 1: Handle custom CSV upload (Step 1b)
    if args.import_path:
        csv_path = Path(args.import_path)
        if not csv_path.exists():
            leads_engine.log_msg("ERROR", f"Specified CSV file not found: {args.import_path}")
            sys.exit(1)
        
        leads_engine.log_msg("INFO", f"Importing custom leads from {args.import_path}...")
        custom_leads = []
        try:
            with open(csv_path, "r", encoding="utf-8") as f:
                import csv
                reader = csv.DictReader(f)
                for row in reader:
                    email = row.get("email", row.get("Email", "")).strip()
                    if not email:
                        continue
                    
                    # Ensure CTO positions are strictly skipped
                    title = row.get("title", row.get("Title", "")).strip()
                    if leads_engine.is_cto(title):
                        leads_engine.log_msg("INFO", f"Skipping CTO lead: {email} (Title: '{title}')")
                        continue

                    # Clean domain
                    domain = row.get("domain", row.get("Domain", "")).strip()
                    if not domain and "@" in email:
                        domain = email.split("@")[1]
                    
                    custom_leads.append({
                        "first_name": row.get("first_name", row.get("First Name", "")).strip(),
                        "last_name": row.get("last_name", row.get("Last Name", "")).strip(),
                        "email": email,
                        "company": row.get("company", row.get("Company", "")).strip(),
                        "domain": domain,
                        "title": title or "Owner"
                    })
            
            added = leads_engine.add_new_leads_to_pool(custom_leads)
            leads_engine.log_msg("OK", f"Imported {len(custom_leads)} records from CSV. Added {added} brand-new unique leads.")
        except Exception as e:
            leads_engine.log_msg("ERROR", f"Failed to parse CSV file: {str(e)}")
            sys.exit(1)

    # Action 2: Lead Generation Crawler (Step 1a)
    if args.harvest is not None:
        leads_engine.generate_new_leads(args.harvest)

    # Action 3: Process and personalized outreach cycle (Step 2)
    if run_step2:
        leads_engine.execute_outbound_cycle(count=args.count, mode=mode, test_address=test_address)

if __name__ == "__main__":
    main()
